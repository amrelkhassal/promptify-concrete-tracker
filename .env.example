# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://promptify:promptify@postgres:5432/promptify

# ── Object storage (Azure Blob) ──────────────────────────────────────────────
# Local dev points at the Azurite emulator; in Azure use a real connection string.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEhibpxoYpbQHgKzZBh+yJPc8b0+8e1Yql0cT1ZW8N1dxkc9c+l6tQ==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
BLOB_CONTAINER_DOCUMENTS=documents
BLOB_CONTAINER_DATASETS=datasets

# ── Auth (Azure App Service Easy Auth) ───────────────────────────────────────
# Empty in local dev → runner falls back to LOCAL_DEV_USER.
LOCAL_DEV_USER=local-dev@example.com

# ── Mistral OCR (Foundry) ────────────────────────────────────────────────────
AZURE_MISTRALOCR_ENDPOINT=https://scanbeton-mistral-ocr-resource.services.ai.azure.com/providers/mistral/azure/ocr
AZURE_MISTRALOCR_API_KEY=

# ── Azure Document Intelligence ──────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── Azure OpenAI (used by the azure_di_gpt provider) ─────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=scanbeton-gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Behaviour ────────────────────────────────────────────────────────────────
SEED_ON_STARTUP=true
LOG_LEVEL=INFO
